generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum AssetType {
  LOGO
  FILE
}

enum FontUsage {
  HEADING
  BODY
  ACCENT
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  password        String?
  name            String
  role            Role         @default(CLIENT)
  companyName     String?
  gscProperty     String?
  gscAccessToken  String?
  gscRefreshToken String?
  gaAccessToken   String?
  gaRefreshToken  String?
  gaPropertyId    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  brandAssets     BrandAsset[]
  brandColors     BrandColor[]
  brandFonts      BrandFont[]
  tasks           Task[]
  projects        Project[]
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model BrandAsset {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         AssetType
  filename     String
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime  @default(now())
}

model BrandColor {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  hex       String
  createdAt DateTime @default(now())
}

model BrandFont {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  usage     FontUsage @default(OTHER)
  createdAt DateTime  @default(now())
}

model Project {
  id          String       @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  color       String       @default("#6366f1")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  messages    Message[]
  cards       Card[]
  columns     CardColumn[]
}

model Message {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  title      String
  body       String    @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  comments   Comment[]
}

model Comment {
  id         String   @id @default(cuid())
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CardColumn {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  cards     Card[]
}

model Card {
  id          String     @id @default(cuid())
  columnId    String
  column      CardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  position    Int        @default(0)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
