generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum AssetType {
  LOGO
  FILE
}

enum FontUsage {
  HEADING
  BODY
  ACCENT
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ApprovalStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
}

enum DeliverableType {
  DESIGN
  COPY
  REPORT
  CONTRACT
  OTHER
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  password        String?
  name            String
  role            Role         @default(CLIENT)
  companyName     String?
  companyId       String?
  company         Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  gscProperty     String?
  gscAccessToken  String?
  gscRefreshToken String?
  gaAccessToken   String?
  gaRefreshToken  String?
  gaPropertyId    String?
  gmbAccessToken  String?
  gmbRefreshToken String?
  gmbAccountId    String?
  gmbLocationId   String?
  notifyTaskCreated     Boolean @default(true)
  notifyTaskCompleted   Boolean @default(true)
  notifyApprovalNeeded  Boolean @default(true)
  notifyProposalSent    Boolean @default(true)
  notifyInvoiceSent     Boolean @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  brandAssets     BrandAsset[]
  brandColors     BrandColor[]
  brandFonts      BrandFont[]
  tasks           Task[]
  projects        Project[]
  deliverables    Deliverable[]
  timeEntries     TimeEntry[]
  proposals       Proposal[]
  invoices        Invoice[]
  assignedTasks   TaskAssignee[]
}

model Proposal {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  status       ProposalStatus @default(DRAFT)
  currency     String         @default("USD")
  validUntil   DateTime?
  sections     Json           @default("[]")
  totalAmount  Float?
  sentAt       DateTime?
  viewedAt     DateTime?
  respondedAt  DateTime?
  acceptedBy   String?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Deliverable {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        DeliverableType @default(OTHER)
  status      ApprovalStatus  @default(PENDING)
  fileUrl     String?
  fileName    String?
  version     Int             @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  comments    ApprovalComment[]
}

model ApprovalComment {
  id            String      @id @default(cuid())
  deliverableId String
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  authorId      String
  authorName    String
  body          String      @db.Text
  action        String?
  createdAt     DateTime    @default(now())
}

model Task {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus    @default(PENDING)
  priority    TaskPriority  @default(MEDIUM)
  dueDate         DateTime?
  visibleToClient Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  timeEntries     TimeEntry[]
  comments        TaskComment[]
  links           TaskLink[]
  assignees       TaskAssignee[]
}

model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([taskId, userId])
}

model TaskLink {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  url       String
  label     String
  createdAt DateTime @default(now())
}

model TaskComment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  body       String   @db.Text
  createdAt  DateTime @default(now())
}

model BrandAsset {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         AssetType
  filename     String
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime      @default(now())
  comments     FileComment[]
}

model FileComment {
  id         String     @id @default(cuid())
  assetId    String
  asset      BrandAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  body       String     @db.Text
  createdAt  DateTime   @default(now())
}

model BrandColor {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  hex       String
  createdAt DateTime @default(now())
}

model BrandFont {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  usage     FontUsage @default(OTHER)
  createdAt DateTime  @default(now())
}

model Project {
  id          String       @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  color       String       @default("#6366f1")
  visibility  String       @default("company")
  memberIds   String[]     @default([])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  messages    Message[]
  cards       Card[]
  columns     CardColumn[]
  timeEntries TimeEntry[]
}

model Message {
  id         String        @id @default(cuid())
  projectId  String
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  title      String
  body       String        @db.Text
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  comments   Comment[]
  links      MessageLink[]
}

model MessageLink {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  label     String
  createdAt DateTime @default(now())
}

model Comment {
  id         String   @id @default(cuid())
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CardColumn {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  cards     Card[]
}

model Card {
  id          String     @id @default(cuid())
  columnId    String
  column      CardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  position    Int        @default(0)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model AppSettings {
  id           String   @id @default("singleton")
  appName      String   @default("Client Portal")
  logoFilename String?
  primaryColor String   @default("#2dd4bf")
  accentColor  String   @default("#6366f1")
  updatedAt    DateTime @updatedAt
}

model Invoice {
  id            String    @id @default(cuid())
  invoilessId   String    @unique
  invoilessUrl  String?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  number        String?
  status        String    @default("Draft")
  currency      String    @default("USD")
  totalAmount   Float?
  dueDate       DateTime?
  invoiceDate   DateTime?
  notes         String?
  sentAt        DateTime?
  lastSyncedAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model DirectMessage {
  id        String    @id @default(cuid())
  fromId    String
  toId      String
  body      String    @db.Text
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  description String?
  minutes     Int
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}
