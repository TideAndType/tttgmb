generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CLIENT
}

enum AssetType {
  LOGO
  FILE
}

enum FontUsage {
  HEADING
  BODY
  ACCENT
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ApprovalStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
}

enum DeliverableType {
  DESIGN
  COPY
  REPORT
  CONTRACT
  OTHER
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  password        String?
  name            String
  role            Role         @default(CLIENT)
  permissions     String[]     @default([])
  companyName     String?
  companyId       String?
  company         Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  gscProperty     String?
  gscAccessToken  String?
  gscRefreshToken String?
  gaAccessToken   String?
  gaRefreshToken  String?
  gaPropertyId    String?
  gmbAccessToken  String?
  gmbRefreshToken String?
  gmbAccountId    String?
  gmbLocationId   String?
  notifyTaskCreated     Boolean @default(true)
  notifyTaskCompleted   Boolean @default(true)
  notifyApprovalNeeded  Boolean @default(true)
  notifyProposalSent    Boolean @default(true)
  notifyInvoiceSent     Boolean @default(true)
  notifyTaskDueReminder Boolean @default(true)
  notifyWeeklyDigest    Boolean @default(true)
  totpSecret       String?
  totpEnabled      Boolean @default(false)
  openLensApiKey   String?
  image            String?  @db.Text
  dashboardLayout  Json?
  createdAt        DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  brandAssets     BrandAsset[]
  brandColors     BrandColor[]
  brandFonts      BrandFont[]
  tasks           Task[]
  projects        Project[]
  deliverables    Deliverable[]
  timeEntries     TimeEntry[]
  proposals       Proposal[]
  invoices        Invoice[]
  assignedTasks   TaskAssignee[]
  meetings        Meeting[]
  trackedKeywords TrackedKeyword[]
  keywordFolders  KeywordFolder[]
}

model KeywordFolder {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime         @default(now())
  keywords  TrackedKeyword[]

  @@unique([userId, name])
  @@index([userId])
}

model TrackedKeyword {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  tags      String[]           @default([])
  folderId  String?
  folder    KeywordFolder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  snapshots KeywordSnapshot[]

  @@unique([userId, query])
  @@index([userId])
  @@index([folderId])
}

model KeywordSnapshot {
  id        String         @id @default(cuid())
  keywordId String
  keyword   TrackedKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  date      DateTime       @db.Date
  position  Float
  clicks    Int            @default(0)
  impressions Int          @default(0)
  ctr       Float          @default(0)
  createdAt DateTime       @default(now())

  @@unique([keywordId, date])
  @@index([keywordId])
}

model Proposal {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  status       ProposalStatus @default(DRAFT)
  currency     String         @default("USD")
  validUntil   DateTime?
  sections     Json           @default("[]")
  totalAmount  Float?
  sentAt       DateTime?
  viewedAt     DateTime?
  lastViewedAt DateTime?
  viewCount    Int            @default(0)
  respondedAt  DateTime?
  acceptedBy   String?
  signatureData String?       @db.Text
  acceptedByIp String?
  notes        String?
  brand        Json?
  shareToken   String?        @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Deliverable {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        DeliverableType @default(OTHER)
  status      ApprovalStatus  @default(PENDING)
  fileUrl     String?
  fileName    String?
  version     Int             @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  comments    ApprovalComment[]
}

model ApprovalComment {
  id            String      @id @default(cuid())
  deliverableId String
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  authorId      String
  authorName    String
  body          String      @db.Text
  action        String?
  createdAt     DateTime    @default(now())
}

model TaskFolder {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  tasks     Task[]
}

model ProjectFolder {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Task {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  folderId    String?
  folder      TaskFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      TaskStatus    @default(PENDING)
  priority    TaskPriority  @default(MEDIUM)
  dueDate         DateTime?
  reminderSentAt  DateTime?
  recurrence      String?
  visibleToClient Boolean       @default(true)
  color           String?
  tags            String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  timeEntries     TimeEntry[]
  comments        TaskComment[]
  links           TaskLink[]
  assignees       TaskAssignee[]
  todos           TaskTodo[]
}

model TaskTodo {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
}

model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([taskId, userId])
}

model TaskLink {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  url       String
  label     String
  createdAt DateTime @default(now())
}

model TaskComment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  body       String   @db.Text
  createdAt  DateTime @default(now())
}

model BrandAsset {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         AssetType
  filename     String
  originalName String
  mimeType     String
  size         Int
  createdAt    DateTime      @default(now())
  comments     FileComment[]
}

model FileComment {
  id         String     @id @default(cuid())
  assetId    String
  asset      BrandAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  body       String     @db.Text
  createdAt  DateTime   @default(now())
}

model BrandColor {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  hex       String
  createdAt DateTime @default(now())
}

model BrandFont {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  usage     FontUsage @default(OTHER)
  createdAt DateTime  @default(now())
}

model Project {
  id          String       @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  color       String       @default("#6366f1")
  visibility  String       @default("company")
  memberIds   String[]     @default([])
  status      String       @default("active")
  startDate   DateTime?
  dueDate     DateTime?
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  messages    Message[]
  cards       Card[]
  columns     CardColumn[]
  timeEntries TimeEntry[]
  ratings     SatisfactionRating[]
  tasks       Task[]
  folderId    String?
  folder      ProjectFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
}

model Message {
  id         String        @id @default(cuid())
  projectId  String
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  title      String
  body       String        @db.Text
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  comments   Comment[]
  links      MessageLink[]
}

model MessageLink {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  label     String
  createdAt DateTime @default(now())
}

model Comment {
  id         String   @id @default(cuid())
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SatisfactionRating {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  score     Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model IntakeForm {
  id          String           @id @default(cuid())
  title       String
  description String?
  // [{ id, label, type: "text"|"textarea"|"select", required, options: [] }]
  fields      Json             @default("[]")
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  responses   IntakeResponse[]
}

model IntakeResponse {
  id          String     @id @default(cuid())
  formId      String
  form        IntakeForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId      String
  // { [fieldId]: value }
  answers     Json       @default("{}")
  submittedAt DateTime   @default(now())

  @@unique([formId, userId])
}

model RecurringInvoice {
  id          String   @id @default(cuid())
  userId      String
  items       Json     @default("[]")
  currency    String   @default("USD")
  notes       String?
  taxes       Json?
  discount    Json?
  interval    String   // weekly | monthly | quarterly
  nextRunAt   DateTime
  lastRunAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Webhook {
  id        String   @id @default(cuid())
  url       String
  events    String[] @default([])
  secret    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  lastFiredAt DateTime?
  lastStatus  Int?
}

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  // { columns: [{ name, position, cards: [{ title, description, priority, label, position }] }] }
  structure   Json     @default("{}")
  createdAt   DateTime @default(now())
}

model CardColumn {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  cards     Card[]
}

model Card {
  id          String     @id @default(cuid())
  columnId    String
  column      CardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  position    Int        @default(0)
  dueDate     DateTime?
  priority    String?
  label       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model AppSettings {
  id           String   @id @default("singleton")
  appName      String   @default("Client Portal")
  logoFilename String?
  primaryColor String   @default("#2dd4bf")
  accentColor  String   @default("#6366f1")
  updatedAt    DateTime @updatedAt
}

model Invoice {
  id            String    @id @default(cuid())
  invoilessId   String    @unique
  invoilessUrl  String?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  number        String?
  status        String    @default("Draft")
  currency      String    @default("USD")
  totalAmount   Float?
  dueDate       DateTime?
  invoiceDate   DateTime?
  notes         String?
  sentAt        DateTime?
  stripeSessionId String?
  stripePaymentId String?
  lastSyncedAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model DirectMessage {
  id        String    @id @default(cuid())
  fromId    String
  toId      String
  body      String    @db.Text
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  description String?
  minutes     Int
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  link      String    @default("/dashboard")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientFile {
  id           String        @id @default(cuid())
  userId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  label        String?
  folder       String?
  version      Int           @default(1)
  versions     FileVersion[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model FileVersion {
  id           String     @id @default(cuid())
  fileId       String
  file         ClientFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  version      Int
  filename     String
  originalName String
  size         Int
  createdAt    DateTime   @default(now())
}

enum ContentStatus {
  IDEA
  IN_PROGRESS
  REVIEW
  SCHEDULED
  PUBLISHED
}

enum ContentType {
  BLOG_POST
  SOCIAL_INSTAGRAM
  SOCIAL_FACEBOOK
  SOCIAL_LINKEDIN
  SOCIAL_TWITTER
  EMAIL
  VIDEO
  PODCAST
  AD
  OTHER
}

model ContentItem {
  id          String        @id @default(cuid())
  userId      String
  title       String
  type        ContentType   @default(OTHER)
  status      ContentStatus @default(IDEA)
  scheduledAt DateTime?
  publishedAt DateTime?
  notes       String?       @db.Text
  url         String?
  tags        String[]      @default([])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL
  EMAIL
  COLD_OUTREACH
  OTHER
}

model Lead {
  id          String     @id @default(cuid())
  name        String
  email       String?
  phone       String?
  company     String?
  source      LeadSource @default(OTHER)
  status      LeadStatus @default(NEW)
  value       Float?
  notes       String?    @db.Text
  tags        String[]   @default([])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  activities  LeadActivity[]
}

model Meeting {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  location    String?
  zoomLink    String?
  notes       String?
  status      String   @default("scheduled")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  note      String   @db.Text
  createdAt DateTime @default(now())
}
